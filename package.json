{
  "name": "@prompt-gloss/monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Gloss any word in your prompt. Claude remembers what it means, forever.",
  "license": "MIT",
  "author": "Philip Nora",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.1.1",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "uiohook-napi"],
    "ignoredBuiltDependencies": ["@vscode/vsce-sign", "keytar"]
  },
  "scripts": {
    "dev": "pnpm --parallel --filter \"@prompt-gloss/server\" --filter \"@prompt-gloss/web\" dev",
    "lint": "eslint .",
    "typecheck": "tsc -b",
    "test": "vitest run --project unit",
    "eval:matcher": "vitest run --project eval",
    "test:e2e": "pnpm --filter \"@prompt-gloss/web\" test:e2e",
    "test:hook": "pnpm --filter \"@prompt-gloss/hook\" build && vitest run --project hook",
    "test:cli": "pnpm --filter \"@prompt-gloss/hook\" build && vitest run --project cli",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm eval:matcher",
    "postinstall": "node scripts/install-hooks.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.5",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.19.1",
    "vitest": "^3.0.0"
  }
}
