{
  "name": "gloss-terminal",
  "displayName": "Gloss Terminal",
  "version": "0.1.0",
  "description": "Attach persistent Gloss context cards to integrated-terminal selections.",
  "license": "MIT",
  "publisher": "prompt-gloss",
  "private": true,
  "type": "commonjs",
  "engines": {
    "vscode": ">=1.93.0"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onCommand:gloss.captureSelection",
    "onView:gloss.cardPanel"
  ],
  "contributes": {
    "commands": [
      {
        "command": "gloss.captureSelection",
        "title": "Gloss: attach context to selection"
      }
    ],
    "keybindings": [
      {
        "command": "gloss.captureSelection",
        "key": "ctrl+alt+g",
        "mac": "cmd+alt+g",
        "when": "terminalFocus && terminalTextSelected"
      }
    ],
    "menus": {
      "terminal/context": [
        {
          "command": "gloss.captureSelection",
          "when": "terminalFocus && terminalTextSelected"
        }
      ]
    },
    "viewsContainers": {
      "panel": [
        {
          "id": "gloss",
          "title": "Gloss",
          "icon": "media/gloss.svg"
        }
      ]
    },
    "views": {
      "gloss": [
        {
          "id": "gloss.cardPanel",
          "name": "Gloss Card",
          "type": "webview"
        }
      ]
    }
  },
  "scripts": {
    "build": "node esbuild.mjs && tsc -b --pretty false",
    "package": "vsce package",
    "test:vscode": "pnpm --filter @prompt-gloss/core build && pnpm --filter @prompt-gloss/panel-ui build && tsc -p test/tsconfig.json --pretty false && node test/prepareOut.mjs && node out/test/runTest.js"
  },
  "dependenciesMeta": {
    "@vscode/vsce-sign": {
      "built": false
    },
    "keytar": {
      "built": false
    }
  },
  "dependencies": {
    "@prompt-gloss/core": "workspace:*",
    "@prompt-gloss/panel-ui": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/vscode": "^1.93.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "3.2.2",
    "esbuild": "^0.24.2",
    "glob": "^13.0.6",
    "mocha": "^11.7.6",
    "typescript": "^5.7.3"
  }
}
