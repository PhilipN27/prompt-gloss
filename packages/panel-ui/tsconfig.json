{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "composite": true,
    "declaration": true,
    "noEmit": false
  },
  "references": [{ "path": "../core" }],
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["dist"]
}
