# Don't re-run `pnpm install` as a precheck before every script. The precheck
# treats esbuild's ignored-build-script warning as fatal, which breaks
# `pnpm typecheck`/`test`/etc. Builds are approved via package.json
# (pnpm.onlyBuiltDependencies); the esbuild platform binary is present anyway.
verify-deps-before-run=false
